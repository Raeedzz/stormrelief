# Mapbox — public token (pk.…) for tiles + geocoding
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# Resend — leave empty to log emails to console (demo mode)
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

# Cookie session secret — must be at least 32 chars
SESSION_SECRET=replace_with_long_random_string_at_least_32_chars_yes_really
